{
  "name": "cryer",
  "version": "0.1.0",
  "description": "Centralized beta tester update system — automated weekly emails with per-product voice powered by LLM drafts",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cryer-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && npm start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "mcp": "node dist/mcp.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@supabase/supabase-js": "^2.47.10",
    "google-auth-library": "^10.5.0",
    "google-spreadsheet": "^5.2.0",
    "octokit": "^4.0.2",
    "openai": "^6.24.0",
    "resend": "^4.1.2",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
