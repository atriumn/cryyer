# Cryyer Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.

# =============================================================================
# Common
# =============================================================================

# GitHub personal access token (repo scope required)
GITHUB_TOKEN=ghp_your_token_here

# Resend API key for email delivery
RESEND_API_KEY=re_your_key_here

# Default sender email address
FROM_EMAIL=updates@yourdomain.com

# Default sender name (optional; defaults to "Cryyer Updates")
FROM_NAME=Your Product Updates

# =============================================================================
# LLM Provider (choose one)
# =============================================================================

# LLM backend: "anthropic" (default), "openai", or "gemini"
LLM_PROVIDER=anthropic

# Override the default model for the chosen provider (optional)
# LLM_MODEL=claude-3-5-haiku-latest

# Anthropic API key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# OpenAI API key (required when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your_key_here

# Google Gemini API key (required when LLM_PROVIDER=gemini)
# GEMINI_API_KEY=your_key_here

# =============================================================================
# Subscriber Store (choose one)
# =============================================================================

# Subscriber storage backend: "supabase" (default), "json", or "google-sheets"
SUBSCRIBER_STORE=supabase

# --- Supabase (default) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# --- JSON file store ---
# SUBSCRIBER_STORE=json
# SUBSCRIBERS_JSON_PATH=./subscribers.json
# EMAIL_LOG_JSON_PATH=./email-log.json

# --- Google Sheets store ---
# SUBSCRIBER_STORE=google-sheets
# GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
# GOOGLE_SERVICE_ACCOUNT_EMAIL=cryyer@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# =============================================================================
# Workflow-Specific
# =============================================================================

# "owner/repo" for draft issue creation (used by draft.ts and MCP server)
CRYYER_REPO=owner/repo

# Project root path (MCP server only; defaults to current working directory)
# CRYYER_ROOT=/path/to/cryyer

# Set by GitHub Actions in the send-on-close workflow — do not set manually
# ISSUE_NUMBER=42

# Set automatically by GitHub Actions — do not set manually
# GITHUB_REPOSITORY=owner/repo

# =============================================================================
# Dry-run / Preview Mode
# =============================================================================

# Set to "true" to print email drafts to stdout instead of sending or creating issues
# DRY_RUN=true
