---
---

<section class="relative overflow-hidden px-6 pt-32 pb-20 md:pt-40 md:pb-28">
  <!-- Gradient background -->
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-b from-[#1a2736]/50 via-transparent to-transparent"
  >
  </div>
  <div
    class="pointer-events-none absolute top-20 left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full bg-[#c9a84c]/5 blur-3xl"
  >
  </div>

  <div class="relative mx-auto max-w-4xl text-center">
    <img src="/logo.png" alt="Cryyer" class="mx-auto mb-8 h-24 w-24 md:h-32 md:w-32" />

    <h1 class="mb-6 text-4xl font-bold tracking-tight text-white md:text-6xl">
      Automated product updates
      <br />
      <span class="text-[#c9a84c]">powered by AI</span>
    </h1>

    <p class="mx-auto mb-10 max-w-2xl text-lg text-[#bec4ca] md:text-xl">
      Cryyer gathers your GitHub activity, drafts personalized emails with AI, and sends them —
      with a human review step in between.
    </p>

    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/getting-started"
        class="rounded-lg border border-[#c9a84c] px-6 py-3 font-medium text-[#c9a84c] transition-colors hover:bg-[#c9a84c]/10"
      >
        Get Started
      </a>
      <a
        href="#waitlist"
        class="rounded-lg bg-[#c9a84c] px-6 py-3 font-medium text-[#0d1520] transition-colors hover:bg-[#d4b85d]"
      >
        Join the Waitlist
      </a>
    </div>
  </div>
</section>
