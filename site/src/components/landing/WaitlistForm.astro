---
---

<section id="waitlist" class="px-6 py-20 md:py-28">
  <div class="mx-auto max-w-xl text-center">
    <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl">Get early access</h2>
    <p class="mb-8 text-lg text-[#bec4ca]">
      Join the waitlist for Cryyer's hosted service. We'll let you know when it's ready.
    </p>

    <form id="waitlist-form" class="mx-auto flex max-w-md flex-col gap-3 sm:flex-row">
      <input
        type="email"
        name="email"
        required
        placeholder="you@example.com"
        class="flex-1 rounded-lg border border-white/10 bg-white/[0.05] px-4 py-3 text-white placeholder-[#7c8694] transition-colors focus:border-[#c9a84c] focus:outline-none"
      />
      <button
        type="submit"
        class="shrink-0 rounded-lg bg-[#c9a84c] px-6 py-3 font-medium text-[#0d1520] transition-colors hover:bg-[#d4b85d] disabled:opacity-50"
      >
        Join Waitlist
      </button>
    </form>

    <p id="waitlist-message" class="mt-4 hidden text-sm"></p>
  </div>
</section>

<script>
  const form = document.getElementById("waitlist-form") as HTMLFormElement;
  const message = document.getElementById("waitlist-message") as HTMLParagraphElement;
  const button = form.querySelector("button") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = new FormData(form).get("email") as string;

    button.disabled = true;
    button.textContent = "Joining...";
    message.classList.add("hidden");

    try {
      const res = await fetch("/api/waitlist", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });

      const data = await res.json();

      if (res.ok) {
        message.textContent = "You're on the list! We'll be in touch.";
        message.className = "mt-4 text-sm text-green-400";
        form.reset();
      } else {
        message.textContent = data.error || "Something went wrong. Please try again.";
        message.className = "mt-4 text-sm text-red-400";
      }
    } catch {
      message.textContent = "Network error. Please try again.";
      message.className = "mt-4 text-sm text-red-400";
    } finally {
      button.disabled = false;
      button.textContent = "Join Waitlist";
    }
  });
</script>
