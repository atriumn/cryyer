---
---

<section id="how-it-works" class="px-6 py-20 md:py-28">
  <div class="mx-auto max-w-4xl">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl">Two-stage pipeline</h2>
      <p class="text-lg text-[#bec4ca]">
        Automated drafting with human approval. Nothing sends without your sign-off.
      </p>
    </div>

    <div class="relative">
      <!-- Connector line -->
      <div
        class="absolute top-0 bottom-0 left-8 hidden w-px bg-gradient-to-b from-[#c9a84c]/50 via-[#c9a84c]/20 to-transparent md:left-1/2 md:block"
      >
      </div>

      <!-- Step 1 -->
      <div class="relative mb-12 md:mb-16">
        <div class="flex flex-col items-start gap-6 md:flex-row md:items-center">
          <div class="flex-1 md:pr-12 md:text-right">
            <div class="mb-2 text-sm font-medium tracking-wider text-[#c9a84c] uppercase">
              Monday (automated)
            </div>
            <h3 class="mb-3 text-2xl font-bold text-white">Weekly Draft</h3>
            <p class="text-[#bec4ca]">
              Cryyer gathers merged PRs, releases, and notable commits from your GitHub repo. An LLM
              drafts a personalized email in your product's voice and creates a GitHub issue for
              review.
            </p>
          </div>

          <div
            class="z-10 flex h-16 w-16 shrink-0 items-center justify-center rounded-full border-2 border-[#c9a84c] bg-[#0d1520] text-xl font-bold text-[#c9a84c]"
          >
            1
          </div>

          <div class="hidden flex-1 md:block"></div>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="relative">
        <div class="flex flex-col items-start gap-6 md:flex-row md:items-center">
          <div class="hidden flex-1 md:block"></div>

          <div
            class="z-10 flex h-16 w-16 shrink-0 items-center justify-center rounded-full border-2 border-[#c9a84c] bg-[#0d1520] text-xl font-bold text-[#c9a84c]"
          >
            2
          </div>

          <div class="flex-1 md:pl-12">
            <div class="mb-2 text-sm font-medium tracking-wider text-[#c9a84c] uppercase">
              When you're ready
            </div>
            <h3 class="mb-3 text-2xl font-bold text-white">Send on Close</h3>
            <p class="text-[#bec4ca]">
              Review and edit the draft in GitHub. When you close the issue, Cryyer sends the email
              to all subscribers via Resend and posts delivery stats as a comment.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
